rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user a designated Admin?
    // Set this with a Firebase Auth custom claim: { admin: true }.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Feedback: Anyone logged in can send feedback, only Admin can read it.
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Analytics: Anyone can log events (create), only Admin can read/manage.
    match /analytics/{docId} {
      allow create: if true; // Allow anonymous logging if needed
      allow read, update, delete: if isAdmin();
    }

    // Users: Users can only read/write their own data (including subcollections)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
